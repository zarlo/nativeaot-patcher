<Project>
  <ItemGroup>
    <!-- There are some Interop.Sys methods that cannot be plugged directly or through their callers, so
         we add them here to enable static linking. -->
    <!-- For more information see: https://learn.microsoft.com/en-us/dotnet/core/deploying/native-aot/interop -->
    <DirectPInvokeList Include="&quot;$(MSBuildThisFileDirectory)\InteropAPI.txt&quot;" />
  </ItemGroup>
</Project>