<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <!-- Input path passed as a parameter (Correct version [oops])-->
    <IsoRoot Condition="'$(IsoRoot)' == ''">$(DefaultIsoRoot)</IsoRoot>

    <!-- Ensure IsoRoot is an absolute path before converting to Cygwin format -->
    <IsoRootAbsolute>$([System.IO.Path]::GetFullPath('$(IsoRoot)'))</IsoRootAbsolute>

    <!-- Replace ':' with '' (remove colon after drive letter) -->
    <IsoRootNoColon>$([System.String]::Copy('$(IsoRootAbsolute)').Replace(':', ''))</IsoRootNoColon>

    <!-- Replace backslashes with slashes -->
    <IsoRootSlashes>$([System.String]::Copy('$(IsoRootNoColon)').Replace('\', '/'))</IsoRootSlashes>

    <!-- Add cygdrive prefix -->
    <FinalIsoRoot>/cygdrive/$(IsoRootSlashes)</FinalIsoRoot>
    <XorrisoBinary>$(LOCALAPPDATA)\Cosmos\Tools\xorriso\xorriso.exe</XorrisoBinary>
  </PropertyGroup>

<Target Name="ValidateCommonTools" BeforeTargets="GetLinker">
  <Error Condition="!Exists('$(XorrisoBinary)')" Text="Cosmos Xorriso not found at $(XorrisoBinary). Please install Cosmos Tools using 'cosmos install'." />
</Target>

<Target Name="GetLinker">
  <PropertyGroup>
    <LdLinkerPath Condition="'$(LdLinkerPath)' == ''">$(LOCALAPPDATA)\Cosmos\Tools\llvm-tools\bin\ld.lld</LdLinkerPath>
  </PropertyGroup>
  <Error Condition="!Exists('$(LdLinkerPath)')" Text="Cosmos LdLinker not found at $(LdLinkerPath). Please install Cosmos Tools using 'cosmos install'." />
</Target>

</Project>
