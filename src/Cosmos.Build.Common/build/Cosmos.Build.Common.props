<Project>
  <PropertyGroup>
    <LinkTargetDependsOn>GetLinker;$(LinkTargetDependsOn)</LinkTargetDependsOn>
    <!-- Path to the shared Cosmos.Build.Common tasks assembly -->
    <CosmosCommonTasksAssembly Condition="'$(CosmosCommonTasksAssembly)' == ''">$(MSBuildThisFileDirectory)/../tasks/netstandard2.0/Cosmos.Build.Common.dll</CosmosCommonTasksAssembly>
  </PropertyGroup>

  <!-- Shared build cache task used by Patcher, ILC, and other build steps -->
  <UsingTask TaskName="Cosmos.Build.Common.Tasks.ComputeInputsHashTask"
             AssemblyFile="$(CosmosCommonTasksAssembly)" />

  <!-- Tool resolver used by every per-tool targets file (CC, Asm, Common). -->
  <UsingTask TaskName="Cosmos.Build.Common.Tasks.ResolveCosmosToolTask"
             AssemblyFile="$(CosmosCommonTasksAssembly)" />

  <!-- Import architecture picker early so CosmosArch and DefineConstants are set -->
  <!-- Note: Do NOT set default RuntimeIdentifier here - it interferes with multi-arch builds -->
  <!-- The ArchitecturePicker.props will default CosmosArch to x64 if not specified -->
  <Import Project="Cosmos.ArchitecturePicker.props" />
</Project>
