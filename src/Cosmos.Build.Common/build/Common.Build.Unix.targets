<Project>
  <PropertyGroup>
    <XorrisoBinary Condition="'$(XorrisoBinary)' == '' AND Exists('$(HOME)/.cosmos/tools/xorriso/xorriso')">$(HOME)/.cosmos/tools/xorriso/xorriso</XorrisoBinary>
    <XorrisoBinary Condition="'$(XorrisoBinary)' == ''">xorriso</XorrisoBinary>
    <FinalIsoRoot>$(IsoRoot)</FinalIsoRoot>
  </PropertyGroup>

    <Target Name="GetLinker">
        <PropertyGroup>
            <LdLinkerPath Condition="'$(LdLinkerPath)' == '' AND Exists('$(HOME)/.cosmos/tools/llvm-tools/bin/ld.lld')">$(HOME)/.cosmos/tools/llvm-tools/bin/ld.lld</LdLinkerPath>
            <LdLinkerPath Condition="'$(LdLinkerPath)' == ''">ld.lld</LdLinkerPath>
            <LdLinkerPath>$(LdLinkerPath.Trim())</LdLinkerPath>
        </PropertyGroup>
    </Target>
</Project>
