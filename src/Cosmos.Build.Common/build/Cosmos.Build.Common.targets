<Project>
  <!-- Import architecture detection and configuration -->
  <Import Project="Cosmos.Architecture.props"/>

  <PropertyGroup>
    <CosmosOutputPath Condition="$(CosmosOutputPath) == ''">$([MSBuild]::NormalizePath('$(OutputPath)', 'cosmos'))</CosmosOutputPath>
    <CosmosIntermediateOutputPath Condition="$(CosmosIntermediateOutputPath) == ''">$([MSBuild]::NormalizePath('$(IntermediateOutputPath)', 'cosmos'))</CosmosIntermediateOutputPath>
    <IsoRoot Condition="$(IsoRoot) == ''">$([MSBuild]::NormalizePath('$(CosmosIntermediateOutputPath)', 'iso_root'))</IsoRoot>
    <IsoOutput Condition="$(IsoOutput) == ''">$([MSBuild]::NormalizePath('$(CosmosOutputPath)', '$(AssemblyName).iso'))</IsoOutput>
  </PropertyGroup>

  <!-- Platform detection -->
  <PropertyGroup>
    <IsWindows Condition="'$(OS)' == 'Windows_NT'">true</IsWindows>
    <IsMacOS Condition="'$(OS)' != 'Windows_NT' AND $([MSBuild]::IsOSPlatform('OSX'))">true</IsMacOS>
    <IsLinux Condition="'$(OS)' != 'Windows_NT' AND '$(IsMacOS)' != 'true'">true</IsLinux>
  </PropertyGroup>

  <Import Project="Common.Build.Unix.targets" Condition="'$(IsLinux)' == 'true'"/>
  <Import Project="Common.Build.macOS.targets" Condition="'$(IsMacOS)' == 'true'"/>
  <Import Project="Common.Build.Windows.targets" Condition="'$(IsWindows)' == 'true'"/>

  <!-- Content-hash based linker caching: hash all .o/.obj + exports file -->
  <Target Name="CheckLinkCache" DependsOnTargets="$(LinkTargetDependsOn)">
    <PropertyGroup>
      <ElfBinary>$([MSBuild]::NormalizePath('$(OutputPath)', '$(AssemblyName).elf'))</ElfBinary>
      <AsmObjDir>$([MSBuild]::NormalizePath('$(IntermediateOutputPath)', 'cosmos', 'asm'))</AsmObjDir>
      <CObjDir>$([MSBuild]::NormalizePath('$(IntermediateOutputPath)', 'cosmos', 'cobj'))</CObjDir>
      <_LinkCacheFile>$([MSBuild]::NormalizePath('$(IntermediateOutputPath)', 'cosmos', '.link-hash'))</_LinkCacheFile>
    </PropertyGroup>

    <ItemGroup>
      <_LinkInputFiles Include="$(AsmObjDir)/*.obj"/>
      <_LinkInputFiles Include="$(CObjDir)/*.obj"/>
      <_LinkInputFiles Include="$(CObjDir)/*.o"/>
      <_LinkInputFiles Include="%(ManagedBinary.OutputFile)"/>
      <_LinkInputFiles Include="$(ExportsFile)" Condition="'$(ExportsFile)' != '' AND Exists('$(ExportsFile)')"/>
    </ItemGroup>

    <ComputeInputsHashTask InputFiles="@(_LinkInputFiles)">
      <Output TaskParameter="Hash" PropertyName="_CurrentLinkHash" />
    </ComputeInputsHashTask>

    <ReadLinesFromFile File="$(_LinkCacheFile)" Condition="Exists('$(_LinkCacheFile)')">
      <Output TaskParameter="Lines" ItemName="_PreviousLinkHashLines" />
    </ReadLinesFromFile>

    <PropertyGroup>
      <_PreviousLinkHash>@(_PreviousLinkHashLines)</_PreviousLinkHash>
      <_LinkCacheHit Condition="'$(_CurrentLinkHash)' != '' AND '$(_CurrentLinkHash)' == '$(_PreviousLinkHash)' AND Exists('$(ElfBinary)')">true</_LinkCacheHit>
    </PropertyGroup>

    <Message Condition="'$(_LinkCacheHit)' == 'true'" Importance="High"
             Text="Linker cache hit — skipping link (hash: $(_CurrentLinkHash))" />
  </Target>

  <!-- Wrapper: runs CheckLinkCache, then conditionally invokes the link work via CallTarget. -->
  <Target Name="LinkTarget" DependsOnTargets="CheckLinkCache" AfterTargets="Build">
    <CallTarget Targets="_LinkTargetCore" Condition="'$(_LinkCacheHit)' != 'true'" />
  </Target>

  <Target Name="_LinkTargetCore">
    <ItemGroup>
      <ObjFiles Include="$(AsmObjDir)/*.obj"/>
      <!-- GCC produced object files -->
      <ObjFiles Include="$(CObjDir)/*.obj"/>
      <ObjFiles Include="$(CObjDir)/*.o"/>
    </ItemGroup>

    <PropertyGroup>
      <!-- Framework linker script paths (included in package) -->
      <FrameworkLinkerScript>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', 'Linker', 'linker.$(CosmosArch).ld'))</FrameworkLinkerScript>
      <FallbackLinkerScript>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', 'Linker', 'linker.ld'))</FallbackLinkerScript>
      <!-- User project linker script paths (for backward compatibility) -->
      <UserLinkerScript>$([MSBuild]::NormalizePath('Linker', 'linker.$(CosmosArch).ld'))</UserLinkerScript>
      <UserFallbackLinkerScript>$([MSBuild]::NormalizePath('Linker', 'linker.ld'))</UserFallbackLinkerScript>
    </PropertyGroup>

    <ItemGroup>
      <!-- Arguments for ld.lld -->
      <!-- Priority: User project -> Framework architecture-specific -> Framework fallback -->
      <LinkerArgs Include="-T $(UserLinkerScript)" Condition="Exists('$(UserLinkerScript)')"/>
      <LinkerArgs Include="-T $(FrameworkLinkerScript)" Condition="!Exists('$(UserLinkerScript)') AND Exists('$(FrameworkLinkerScript)')"/>
      <LinkerArgs Include="-T $(UserFallbackLinkerScript)" Condition="!Exists('$(UserLinkerScript)') AND !Exists('$(FrameworkLinkerScript)') AND Exists('$(UserFallbackLinkerScript)')"/>
      <LinkerArgs Include="-T $(FallbackLinkerScript)" Condition="!Exists('$(UserLinkerScript)') AND !Exists('$(FrameworkLinkerScript)') AND !Exists('$(UserFallbackLinkerScript)') AND Exists('$(FallbackLinkerScript)')"/>
      <LinkerArgs Include="-m $(CosmosLinkerEmulation)"/>
      <LinkerArgs Include="-nostdlib"/>
      <LinkerArgs Include="-static"/>
      <LinkerArgs Include="-z max-page-size=0x1000"/>
      <LinkerArgs Include="%(ManagedBinary.OutputFile)"/>
      <LinkerArgs Include="@(ObjFiles->'%(FullPath)')"/>
      <LinkerArgs Include="-o $(ElfBinary)"/>
      <LinkerArgs Include="--error-limit=0"/>
      <LinkerArgs Condition="$(ExportsFile) != ''" Include="--version-script &quot;$(ExportsFile)&quot;"/>
    </ItemGroup>

    <Error Condition="'$(LdLinkerPath)' == ''" Text="Error: 'ld.lld' linker was not found. Install llvm or set the 'LdLinkerPath' property"/>
    <Exec Command="&quot;$(LdLinkerPath)&quot; @(LinkerArgs, ' ')"/>
    <Message Text="Built ELF: $(AssemblyName).elf" Importance="High"/>

    <!-- Write cache hash after successful linking -->
    <WriteLinesToFile File="$(_LinkCacheFile)" Lines="$(_CurrentLinkHash)" Overwrite="true" />
  </Target>

  <!-- Content-hash based ISO caching: hash ELF + limine.conf -->
  <Target Name="CheckIsoCache" DependsOnTargets="LinkTarget">
    <PropertyGroup>
      <_IsoCacheFile>$([MSBuild]::NormalizePath('$(IntermediateOutputPath)', 'cosmos', '.iso-hash'))</_IsoCacheFile>
      <_LimineConf>$([MSBuild]::NormalizePath('$(MSBuildProjectDirectory)', 'Bootloader', 'limine.conf'))</_LimineConf>
    </PropertyGroup>

    <ItemGroup>
      <_IsoInputFiles Include="$(ElfBinary)" Condition="Exists('$(ElfBinary)')"/>
      <_IsoInputFiles Include="$(_LimineConf)" Condition="Exists('$(_LimineConf)')"/>
    </ItemGroup>

    <ComputeInputsHashTask InputFiles="@(_IsoInputFiles)">
      <Output TaskParameter="Hash" PropertyName="_CurrentIsoHash" />
    </ComputeInputsHashTask>

    <ReadLinesFromFile File="$(_IsoCacheFile)" Condition="Exists('$(_IsoCacheFile)')">
      <Output TaskParameter="Lines" ItemName="_PreviousIsoHashLines" />
    </ReadLinesFromFile>

    <PropertyGroup>
      <_PreviousIsoHash>@(_PreviousIsoHashLines)</_PreviousIsoHash>
      <_IsoCacheHit Condition="'$(_CurrentIsoHash)' != '' AND '$(_CurrentIsoHash)' == '$(_PreviousIsoHash)' AND Exists('$(IsoOutput)')">true</_IsoCacheHit>
    </PropertyGroup>

    <Message Condition="'$(_IsoCacheHit)' == 'true'" Importance="High"
             Text="ISO cache hit — skipping ISO creation (hash: $(_CurrentIsoHash))" />
  </Target>

  <!-- Wrapper: runs CheckIsoCache, then conditionally invokes the ISO work via CallTarget. -->
  <Target Name="BuildISO" DependsOnTargets="CheckIsoCache" AfterTargets="LinkTarget">
    <CallTarget Targets="_BuildIsoCore" Condition="'$(_IsoCacheHit)' != 'true'" />
  </Target>

  <Target Name="_BuildIsoCore">
    <Message Text="Creating ISO image with Limine..." Importance="High"/>

    <!-- Remove old ISO directory if it exists -->
    <RemoveDir Directories="$(IsoRoot)"/>

    <!-- Limine bootloader files bundled in the NuGet package (tools/Limine/) -->
    <PropertyGroup>
      <LiminePkgDir>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', '..', 'tools', 'Limine'))</LiminePkgDir>
      <LimineDir>$([MSBuild]::NormalizePath('$(CosmosIntermediateOutputPath)', 'limine'))</LimineDir>
      <LimineBinary Condition="'$(IsWindows)' == 'true'">$([MSBuild]::NormalizePath('$(LimineDir)', 'limine.exe'))</LimineBinary>
      <LimineBinary Condition="'$(IsWindows)' != 'true'">$([MSBuild]::NormalizePath('$(LimineDir)', 'limine'))</LimineBinary>
      <IsoRootBoot>$([MSBuild]::NormalizePath('$(IsoRoot)', 'boot'))</IsoRootBoot>
      <IsoRootBootLimine>$([MSBuild]::NormalizePath('$(IsoRoot)', 'boot', 'limine'))</IsoRootBootLimine>
      <IsoRootEfiBoot>$([MSBuild]::NormalizePath('$(IsoRoot)', 'EFI', 'BOOT'))</IsoRootEfiBoot>
    </PropertyGroup>

    <!-- Create new directories for Limine and EFI boot files -->
    <MakeDir Directories="$(LimineDir)"/>
    <MakeDir Directories="$(IsoRootBootLimine)"/>
    <MakeDir Directories="$(IsoRootEfiBoot)"/>

    <!-- Copy bundled Limine files from NuGet package to intermediate output -->
    <ItemGroup>
      <BundledLimineFiles Include="$(LiminePkgDir)/*"/>
    </ItemGroup>
    <Copy SourceFiles="@(BundledLimineFiles)" DestinationFolder="$(LimineDir)" SkipUnchangedFiles="true"/>

    <!-- On Unix, build the limine CLI tool from the bundled source -->
    <Exec Condition="'$(IsWindows)' != 'true'" Command="make -C &quot;$(LimineDir)&quot;"/>

    <!-- Copy built ELF and Limine config to ISO root -->
    <Copy SourceFiles="$(ElfBinary)" DestinationFolder="$(IsoRootBoot)"/>
    <Copy SourceFiles="$([MSBuild]::NormalizePath('$(MSBuildProjectDirectory)', 'Bootloader', 'limine.conf'))" DestinationFolder="$(IsoRootBootLimine)"/>

    <!-- Copy Limine files -->
    <Copy SourceFiles="$([MSBuild]::NormalizePath('$(LimineDir)', 'limine-bios.sys'));$([MSBuild]::NormalizePath('$(LimineDir)', 'limine-bios-cd.bin'));$([MSBuild]::NormalizePath('$(LimineDir)', 'limine-uefi-cd.bin'))" DestinationFolder="$(IsoRootBootLimine)"/>
    <!-- Copy architecture-specific UEFI bootloader -->
    <Copy Condition="'$(CosmosArch)' == 'x64'" SourceFiles="$([MSBuild]::NormalizePath('$(LimineDir)', 'BOOTX64.EFI'))" DestinationFolder="$(IsoRootEfiBoot)"/>
    <Copy Condition="'$(CosmosArch)' == 'arm64'" SourceFiles="$([MSBuild]::NormalizePath('$(LimineDir)', 'BOOTAA64.EFI'))" DestinationFolder="$(IsoRootEfiBoot)"/>

    <!-- Arguments for xorriso to generate an ISO with MBR and UEFI boot entries -->
    <ItemGroup>
      <XorrisoArgs Include="-as mkisofs"/>
      <XorrisoArgs Include="-R"/>
      <XorrisoArgs Include="-J"/>
      <XorrisoArgs Include="-b boot/limine/limine-bios-cd.bin"/>
      <XorrisoArgs Include="-no-emul-boot"/>
      <XorrisoArgs Include="-boot-load-size 4"/>
      <XorrisoArgs Include="-boot-info-table"/>
      <XorrisoArgs Include="--efi-boot boot/limine/limine-uefi-cd.bin"/>
      <XorrisoArgs Include="-efi-boot-part"/>
      <XorrisoArgs Include="--efi-boot-image"/>
      <XorrisoArgs Include="--protective-msdos-label $(FinalIsoRoot)"/>
      <XorrisoArgs Include="-o $(IsoOutput)"/>
    </ItemGroup>

    <!-- Create Output Dir -->
    <MakeDir Directories="$(CosmosOutputPath)"/>

    <!-- Build the ISO -->
    <Exec Command="&quot;$(XorrisoBinary)&quot; @(XorrisoArgs, ' ')"/>

    <!-- Install Limine on the new ISO -->
    <Exec Command="&quot;$(LimineBinary)&quot; bios-install &quot;$(IsoOutput)&quot;"/>
    <Message Text="ISO created at: $(IsoOutput)" Importance="High"/>

    <!-- Write cache hash after successful ISO creation -->
    <WriteLinesToFile File="$(_IsoCacheFile)" Lines="$(_CurrentIsoHash)" Overwrite="true" />
  </Target>

  <Target Name="PublishISO" AfterTargets="Publish">
    <!-- Copy the ISO File to the Publish -->
    <Copy SourceFiles="$(IsoOutput)" DestinationFolder="$(PublishDir)"/>

    <Message Text="✅ ISO Copied to Publish Foder: $(PublishDir)" Importance="High"/>
  </Target>
</Project>
