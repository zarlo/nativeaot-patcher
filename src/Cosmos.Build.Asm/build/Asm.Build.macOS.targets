<Project>
  <Target Name="GetYasm">
    <PropertyGroup>
      <TargetArchitecture Condition="$(RuntimeIdentifier) != ''">$(RuntimeIdentifier.Split('-')[1])</TargetArchitecture>
    </PropertyGroup>

    <PropertyGroup>
      <!-- x64: Use YASM from Cosmos Tools -->
      <YasmPath Condition="'$(YasmPath)' == '' AND ('$(TargetArchitecture)' == 'x64' or '$(TargetArchitecture)' == '') AND Exists('$(HOME)/.cosmos/tools/yasm/yasm')">$(HOME)/.cosmos/tools/yasm/yasm</YasmPath>
      <YasmPath Condition="'$(YasmPath)' == '' AND ('$(TargetArchitecture)' == 'x64' or '$(TargetArchitecture)' == '')">yasm</YasmPath>
      
      <!-- ARM64: Use clang integrated assembler from Cosmos Tools -->
      <YasmPath Condition="'$(YasmPath)' == '' AND '$(TargetArchitecture)' == 'arm64' AND Exists('$(HOME)/.cosmos/tools/llvm-tools/bin/clang')">$(HOME)/.cosmos/tools/llvm-tools/bin/clang</YasmPath>
      <YasmPath Condition="'$(YasmPath)' == '' AND '$(TargetArchitecture)' == 'arm64'">clang</YasmPath>
      
      <YasmPath>$(YasmPath.Trim())</YasmPath>
    </PropertyGroup>
  </Target>
</Project>
