<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <CosmosAsmFrameworkPath>$(IntermediateOutputPath)cosmos-asm\</CosmosAsmFrameworkPath>
  </PropertyGroup>

  <PropertyGroup>
    <CosmosAsmTasksAssembly
      Condition="'$(CosmosAsmTasksAssembly)' == '' OR !Exists('$(CosmosAsmTasksAssembly)')">$(MSBuildThisFileDirectory)\..\tasks\netstandard2.0\Cosmos.Build.Asm.dll</CosmosAsmTasksAssembly>
  </PropertyGroup>

  <UsingTask TaskName="Cosmos.Build.Asm.Tasks.YasmBuildTask" AssemblyFile="$(CosmosAsmTasksAssembly)"/>
</Project>
