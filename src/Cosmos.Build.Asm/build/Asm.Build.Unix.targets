<Project>
  <Target Name="GetYasm">
    <PropertyGroup>
      <TargetArchitecture Condition="$(RuntimeIdentifier) != ''">$(RuntimeIdentifier.Split('-')[1])</TargetArchitecture>
    </PropertyGroup>

    <PropertyGroup>
      <!-- x64: Use YASM from Cosmos Tools -->
      <YasmPath Condition="'$(YasmPath)' == '' AND ('$(TargetArchitecture)' == 'x64' or '$(TargetArchitecture)' == '')">$(HOME)/.cosmos/tools/yasm/yasm</YasmPath>
      <!-- ARM64: Use clang integrated assembler from Cosmos Tools -->
      <YasmPath Condition="'$(YasmPath)' == '' AND '$(TargetArchitecture)' == 'arm64'">$(HOME)/.cosmos/tools/llvm-tools/bin/clang</YasmPath>
      <YasmPath>$(YasmPath.Trim())</YasmPath>
    </PropertyGroup>

    <Error Condition="!Exists('$(YasmPath)')" Text="Cosmos Yasm not found at $(YasmPath). Please install Cosmos Tools using 'cosmos install'." />
  </Target>
</Project>
