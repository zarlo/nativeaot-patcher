<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Multi-arch package: contains both x64 and arm64 builds -->
    <IsMultiArchPackage>true</IsMultiArchPackage>
    <IsPackable>true</IsPackable>

    <!-- Package Metadata -->
    <PackageId>Cosmos.Kernel</PackageId>
    <Title>Cosmos Kernel Aggregator</Title>
    <Description>Aggregated Cosmos kernel components including boot, core, HAL, runtime, system and plugs.</Description>
    <PackageTags>cosmos;kernel;boot;core;hal;runtime;system;graphics;plugs</PackageTags>
    <RepositoryUrl>https://github.com/valentinbreiz/nativeaot-patcher</RepositoryUrl>
    <PackageProjectUrl>https://github.com/valentinbreiz/nativeaot-patcher</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <!-- Note: Cosmos.Kernel.props is auto-generated and included by Directory.MultiArch.targets -->
    <Content Include="Bootstrap\*.c"  PackagePath="build\Bootstrap\"/>
    <Content Include="Bootstrap\*.h"  PackagePath="build\Bootstrap\"/>
    <!-- Generated by GenerateKmainVersionH below. Lives at the base obj path
         (not the per-configuration IntermediateOutputPath) so the same file is
         visible to the multi-arch build steps and to the final
         `dotnet pack -p:NoBuild=true`. -->
    <Content Include="$(BaseIntermediateOutputPath)Generated\kmain_version.h"
             PackagePath="build\Bootstrap\kmain_version.h"
             Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Cosmos.Kernel.Boot.Limine\Cosmos.Kernel.Boot.Limine.csproj" />
    <ProjectReference Include="..\Cosmos.Kernel.Core\Cosmos.Kernel.Core.csproj" PrivateAssets="none" />
    <ProjectReference Include="..\Cosmos.Kernel.HAL\Cosmos.Kernel.HAL.csproj" PrivateAssets="none" />
    <ProjectReference Include="..\Cosmos.Kernel.HAL.Interfaces\Cosmos.Kernel.HAL.Interfaces.csproj" />
    <ProjectReference Include="..\Cosmos.Kernel.Plugs\Cosmos.Kernel.Plugs.csproj" PrivateAssets="none" />
    <ProjectReference Include="..\Cosmos.Kernel.System\Cosmos.Kernel.System.csproj" PrivateAssets="none" />
  </ItemGroup>

  <!--
    Generate the C# version constant for Cosmos.Kernel.Kernel from $(VersionPrefix).
    This becomes a partial class that adds Kernel.VersionString at compile time.
  -->
  <Target Name="GenerateKernelVersionCs"
          BeforeTargets="CoreCompile"
          Inputs="$(MSBuildProjectFullPath)"
          Outputs="$(IntermediateOutputPath)KernelVersion.g.cs">
    <PropertyGroup>
      <_KernelVersionCsFile>$(IntermediateOutputPath)KernelVersion.g.cs</_KernelVersionCsFile>
    </PropertyGroup>
    <ItemGroup>
      <_KernelVersionCsLine Include="// &lt;auto-generated/&gt;" />
      <_KernelVersionCsLine Include="namespace Cosmos.Kernel%3B" />
      <_KernelVersionCsLine Include="public partial class Kernel" />
      <_KernelVersionCsLine Include="{" />
      <_KernelVersionCsLine Include="    public const string VersionString = &quot;$(VersionPrefix)&quot;%3B" />
      <_KernelVersionCsLine Include="}" />
    </ItemGroup>
    <MakeDir Directories="$(IntermediateOutputPath)" />
    <WriteLinesToFile File="$(_KernelVersionCsFile)"
                      Lines="@(_KernelVersionCsLine)"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true" />
    <ItemGroup>
      <Compile Include="$(_KernelVersionCsFile)" />
      <FileWrites Include="$(_KernelVersionCsFile)" />
    </ItemGroup>
  </Target>

  <!--
    Generate the C version macros for kmain.c from $(VersionPrefix). The header
    ships alongside kmain.h in the package's build/Bootstrap folder so the C
    compilation at the consumer's build time picks it up via #include.
    Written to BaseIntermediateOutputPath (configuration-independent) so the
    same file is shared between the multi-arch builds and `dotnet pack -p:NoBuild=true`.
  -->
  <Target Name="GenerateKmainVersionH"
          BeforeTargets="AssignTargetPaths;_GetPackageFiles"
          Inputs="$(MSBuildProjectFullPath)"
          Outputs="$(BaseIntermediateOutputPath)Generated\kmain_version.h">
    <PropertyGroup>
      <_KmainVersionHFile>$(BaseIntermediateOutputPath)Generated\kmain_version.h</_KmainVersionHFile>
    </PropertyGroup>
    <ItemGroup>
      <_KmainVersionHLine Include="/* &lt;auto-generated/&gt; */" />
      <_KmainVersionHLine Include="#ifndef KMAIN_VERSION_H" />
      <_KmainVersionHLine Include="#define KMAIN_VERSION_H" />
      <_KmainVersionHLine Include="#define COSMOS_VERSION_STRING &quot;$(VersionPrefix)&quot;" />
      <_KmainVersionHLine Include="#define COSMOS_CODENAME &quot;gen3&quot;" />
      <_KmainVersionHLine Include="#endif" />
    </ItemGroup>
    <MakeDir Directories="$(BaseIntermediateOutputPath)Generated" />
    <WriteLinesToFile File="$(_KmainVersionHFile)"
                      Lines="@(_KmainVersionHLine)"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true" />
    <ItemGroup>
      <FileWrites Include="$(_KmainVersionHFile)" />
    </ItemGroup>
  </Target>

  <!-- Multi-arch packaging support -->
  <Import Project="../Directory.MultiArch.targets" />
</Project>
