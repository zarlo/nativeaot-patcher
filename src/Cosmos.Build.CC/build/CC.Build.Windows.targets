<Project>
  <Target Name="GetCC">
    <PropertyGroup>
      <CCPath Condition="'$(CCPath)' == '' AND Exists('$(LOCALAPPDATA)\Cosmos\Tools\llvm-tools\bin\clang.exe')">$(LOCALAPPDATA)\Cosmos\Tools\llvm-tools\bin\clang.exe</CCPath>
      <CCPath Condition="'$(CCPath)' == '' AND Exists('$(LOCALAPPDATA)\Cosmos\Tools\llvm-tools\bin\clang')">$(LOCALAPPDATA)\Cosmos\Tools\llvm-tools\bin\clang</CCPath>
      <CCPath Condition="'$(CCPath)' == ''">clang</CCPath>
      <CCPath>$(CCPath.Trim())</CCPath>
    </PropertyGroup>
  </Target>
</Project>
